{
  "name": "laravel/laravel",
  "type": "project",
  "description": "The Laravel Framework.",
  "keywords": [
    "framework", "laravel"
  ],
  "license": "MIT",
  "require": {
    "php": "^8.3",
    "anlutro/l4-settings": "^1.0",
    "astrotomic/laravel-translatable": "^11.9",
    "carlos-meneses/laravel-mpdf": "^2.1",
    "guzzlehttp/guzzle": "^7.2",
    "hashids/hashids": "^5.0",
    "lab404/laravel-impersonate": "^1.7",
    "laravel/framework": "^12.0",
    "laravel/horizon": "^5.30",
    "laravel/reverb": "^1.0",
    "laravel/sanctum": "^4.0",
    "laravel/tinker": "^2.5",
    "laravel/ui": "^4.0",
    "livewire/livewire": "^3.5",
    "mcamara/laravel-localization": "^2.0",
    "predis/predis": "^2.0",
    "santigarcor/laratrust": "^8.0",
    "staudenmeir/belongs-to-through": "^2.5",
    "staudenmeir/eloquent-has-many-deep": "^1.7",
    "staudenmeir/laravel-adjacency-list": "^1.0",
    "twilio/sdk": "^8.11",
    "yajra/laravel-datatables-oracle": "^12.00"
  },
  "require-dev": {
    "barryvdh/laravel-debugbar": "^3.5",
    "fakerphp/faker": "^1.9.1",
    "mockery/mockery": "^1.4.2",
    "nunomaduro/collision": "^8.1",
    "phpunit/phpunit": "^11.0"
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true
  },
  "extra": {
    "laravel": {
      "dont-discover": []
    }
  },
  "autoload": {
    "files": [
      "app/helpers.php"
    ],
    "psr-4": {
      "App\\": "app/",
      "Database\\Factories\\": "database/factories/",
      "Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "scripts": {
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump", "@php artisan package:discover --ansi"
    ],
    "post-root-package-install": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ],
    "post-create-project-cmd": [
      "@php artisan key:generate --ansi"
    ],
    "dev": [
      "Composer\\Config::disableProcessTimeout", "npx concurrently -k -c \"#93c5fd,#c4b5fd,fb7185\" \"php artisan reverb:start --debug\" \"php artisan horizon\" \"npm run dev\" --names=reverb,horizon,vite"
    ]
  }
}
